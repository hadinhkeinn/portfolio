---
import '../styles/global.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Ha Dinh Kien - Junior Full Stack Engineer Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="cursor-glow" aria-hidden="true"></div>
    <slot />
    <script>
      import { initScrollReveal, initScrollSpy, initMobileMenu } from '../scripts/scrollReveal';
      document.addEventListener('DOMContentLoaded', () => {
        initScrollReveal();
        initScrollSpy();
        initMobileMenu();

        const glow = document.querySelector<HTMLElement>('.cursor-glow');
        if (glow) {
          const moveGlow = (point: { clientX: number; clientY: number }) => {
            glow.style.left = `${point.clientX}px`;
            glow.style.top = `${point.clientY}px`;
          };

          window.addEventListener('mousemove', (event: MouseEvent) => {
            moveGlow(event);
          });
          window.addEventListener('touchmove', (event: TouchEvent) => {
            if (event.touches && event.touches[0]) {
              moveGlow(event.touches[0]);
            }
          }, { passive: true });
        }
      });
    </script>
  </body>
</html>

