---
import '../styles/global.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogImagePath?: string;
  ogImageAlt?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = "Portfolio of Ha Dinh Kien, a full-stack software engineer building scalable SaaS products, real-time systems, and AI-enabled web platforms.",
  canonicalPath = Astro.url.pathname,
  ogImagePath = '/og.png',
  ogImageAlt = 'Ha Dinh Kien, Full-Stack Software Engineer portfolio preview',
  jsonLd
} = Astro.props;

const siteUrl = 'https://portfolio.dinhkien.id.vn';
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const ogImageUrl = new URL(ogImagePath, siteUrl).toString();
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Ha Dinh Kien Portfolio" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <div class="cursor-glow" aria-hidden="true"></div>
    <slot />
    <script>
      import { initScrollReveal, initScrollSpy, initMobileMenu } from '../scripts/scrollReveal';
      document.addEventListener('DOMContentLoaded', () => {
        initScrollReveal();
        initScrollSpy();
        initMobileMenu();

        const glow = document.querySelector<HTMLElement>('.cursor-glow');
        if (glow) {
          const moveGlow = (point: { clientX: number; clientY: number }) => {
            glow.style.left = `${point.clientX}px`;
            glow.style.top = `${point.clientY}px`;
          };

          window.addEventListener('mousemove', (event: MouseEvent) => {
            moveGlow(event);
          });
          window.addEventListener('touchmove', (event: TouchEvent) => {
            if (event.touches && event.touches[0]) {
              moveGlow(event.touches[0]);
            }
          }, { passive: true });
        }
      });
    </script>
  </body>
</html>
