---
import { Github, Linkedin, Mail, Menu } from 'lucide-astro';
---

<!-- Mobile Menu Toggle Button -->
<button 
  id="mobile-menu-toggle" 
  class="md:hidden fixed top-4 right-4 z-50 p-2 bg-[var(--bg-surface)] border border-[var(--border)] rounded-md text-white"
  aria-label="Toggle menu"
>
  <Menu size={20} />
</button>

<!-- Mobile Backdrop -->
<div 
  id="sidebar-backdrop" 
  class="hidden md:hidden fixed inset-0 bg-black/60 z-30 transition-opacity"
></div>

<aside 
  id="sidebar"
  class="fixed inset-y-0 left-0 z-40 w-[280px] bg-[var(--bg)]/95 border-r border-[var(--border)] p-8 flex flex-col h-screen overflow-y-auto transform -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out backdrop-blur-md shadow-[0_0_30px_rgba(0,0,0,0.35)]"
>
  <!-- 1. Identity block -->
  <div class="mb-8">
    <div class="w-12 h-12 rounded-full bg-[rgba(59,130,246,0.15)] border border-[rgba(59,130,246,0.3)] flex items-center justify-center text-[var(--accent)] font-bold mb-4 shadow-[0_0_18px_rgba(59,130,246,0.2)]">
      HK
    </div>
    <h1 class="text-[16px] font-[800] tracking-tight text-white mb-1">Ha Dinh Kien</h1>
    <h2 class="text-[12px] text-[var(--accent)] mb-2 tracking-wide">Full Stack Engineer</h2>
    <div class="flex items-center gap-1.5 text-[11px] text-[var(--muted)]">
      <span class="w-1.5 h-1.5 rounded-full bg-[var(--muted)]"></span>
      Ho Chi Minh City
    </div>
  </div>

  <div class="h-px w-full bg-[rgba(255,255,255,0.06)] mb-6"></div>

  <!-- 2. Navigation -->
  <nav class="mb-auto">
    <ul class="space-y-1.5">
      {[
        { id: 'about', label: 'About' },
        { id: 'experience', label: 'Experience' },
        { id: 'projects', label: 'Projects' },
        { id: 'skills', label: 'Skills' },
        { id: 'education', label: 'Education' },
      ].map(item => (
        <li>
          <a filter
            href={`#${item.id}`}
            data-nav={item.id}
            class="sidebar-close group nav-item flex items-center gap-4 py-2 px-3 rounded-md text-[13px] text-[var(--muted)] hover:text-white hover:bg-[rgba(255,255,255,0.05)] transition-all duration-150 relative"
          >
            <span class="label-text">{item.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <style>
    a[data-nav].nav-item::before {
      content: '';
      position: absolute;
      left: 6px;
      top: 50%;
      transform: translateY(-50%);
      width: 2px;
      height: 14px;
      border-radius: 999px;
      background: transparent;
    }
    a[data-nav].active {
      color: #fff;
      background-color: var(--accent-dim);
    }
    a[data-nav].active::before {
      background: var(--accent);
      box-shadow: 0 0 8px rgba(59, 130, 246, 0.6);
    }
    a[data-nav].active .dot-indicator {
      background-color: var(--accent);
    }
  </style>

  <!-- 3. Social links row -->
  <div class="mt-6 mb-6">
    <div class="text-[10px] uppercase tracking-[0.3em] text-[var(--muted-2)] mb-3">Connect</div>
    <div class="grid grid-cols-4 gap-2">
     {[
       { href: "mailto:hadinhkienn@gmail.com", icon: Mail },
       { href: "https://linkedin.com/in/hadinhkienn", icon: Linkedin },
       { href: "https://github.com/hadinhkienn", icon: Github },
     ].map(link => (
       <a 
         href={link.href} 
         target="_blank" 
         rel="noopener noreferrer"
         class="h-10 flex items-center justify-center rounded-md border border-white/10 bg-[rgba(255,255,255,0.03)] text-[var(--muted)] hover:text-white hover:border-white/20 hover:bg-white/10 transition-all"
       >
        <link.icon size={16} />
       </a>
     ))}
    </div>
  </div>

  <!-- 5. Copyright footer -->
  <div class="text-[10px] text-[var(--muted)] opacity-70 mt-4">
    © 2026 Ha Dinh Kien
  </div>
</aside>

