---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { experiences } from '../data/experience';
import { skillCategories } from '../data/skills';
import { projects } from '../data/projects';
import { ExternalLink } from 'lucide-astro';
---

<BaseLayout title="Ha Dinh Kien | Portfolio">
  <div class="min-h-screen">
    <Sidebar />
    <main class="min-h-screen md:pl-70 pb-16">

      <!-- ─── Section: About ───────────────────────────── -->
      <section id="about" data-section="about" class="content-section pt-16 pb-12 px-6 md:px-14 max-w-5xl mx-auto">
        <div class="flex flex-col gap-6">
          <h2 class="hero-title text-[32px] md:text-[40px] font-[800] text-white tracking-tight" data-reveal>
            Hey, I'm Kien.
          </h2>

          <p class="text-[var(--text-body)] leading-[1.9] text-[15px] max-w-2xl" data-reveal data-delay="50">
            Full Stack Engineer focused on building scalable SaaS products, real-time systems, and AI-driven platforms.
            Currently at CT UAV, where I develop distributed drone monitoring and swarm control systems with real-time communication architectures.
            Previously at CHEK JSC, I helped build a multi-tenant business ecosystem from the ground up, covering backend infrastructure, frontend applications, and cloud deployment workflows.
            <br /><br />
            I enjoy designing reliable systems, optimizing developer workflows, and turning complex technical problems into clean, maintainable products.
          </p>
        </div>
      </section>

      <hr class="section-divider" />

      <!-- ─── Section: Experience ──────────────────────── -->
      <section id="experience" data-section="experience" class="content-section py-12 px-6 md:px-14 max-w-5xl mx-auto">
        <div class="flex items-center gap-4 mb-12" data-reveal>
          <span class="text-[10px] font-semibold text-[var(--accent)] tracking-[0.3em] uppercase">Experience</span>
          <span class="h-px flex-1 bg-gradient-to-r from-[rgba(162,201,255,0.45)] to-transparent section-line"></span>
        </div>

        <div class="space-y-12 border-l border-[var(--border)] ml-1.5">
          {experiences.map((exp, index) => (
              <div class="relative pl-6" data-reveal data-delay={index * 60}>
                <!-- Timeline dot -->
                <div class={`absolute left-[-6px] top-[7px] w-[10px] h-[10px] rounded-full ${
                    exp.isCurrent
                        ? 'bg-[var(--accent)] dot-accent-pulse'
                        : 'bg-[var(--bg-surface)] border border-[var(--border)]'
                }`}></div>

                <div class="text-[11px] text-[var(--muted-2)] font-mono mb-2 tracking-wider">
                  {exp.startDate} — {exp.endDate}
                </div>

                <h4 class="text-[16px] text-white font-[700] mb-1 flex items-center gap-2">
                  {exp.role}
                  {exp.isCurrent && (
                      <span class="inline-flex items-center gap-1.5 text-[10px] font-semibold text-[var(--green-live)] bg-[rgba(74,222,128,0.08)] border border-[rgba(74,222,128,0.25)] rounded-full px-2 py-0.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-[var(--green-live)] dot-pulse inline-block"></span>
                    Now
                  </span>
                  )}
                </h4>

                <div class="text-[13px] text-[var(--accent)] opacity-90 mb-4 font-medium">{exp.company}</div>

                <p class="text-[13px] text-[var(--text-body)] leading-[1.75] mb-4 max-w-2xl">{exp.description}</p>

                <ul class="text-[13px] text-[var(--text-body)] space-y-2 mb-6 ml-4 list-disc marker:text-[var(--accent)] marker:opacity-70">
                  {exp.highlights.map(hl => (
                      <li class="pl-1 leading-relaxed exp-item">{hl}</li>
                  ))}
                </ul>

                <div class="flex flex-wrap gap-2">
                  {exp.techStack.map(tech => (
                      <span class="tech-tag tech-tag-accent font-mono text-[10px] bg-[rgba(162,201,255,0.08)] border border-[rgba(162,201,255,0.22)] text-[var(--accent)] rounded px-2 py-0.5 cursor-default">
                    {tech}
                  </span>
                  ))}
                </div>
              </div>
          ))}
        </div>
      </section>

      <hr class="section-divider" />

      <!-- ─── Section: Projects ────────────────────────── -->
      <section id="projects" data-section="projects" class="content-section py-12 px-6 md:px-14 max-w-5xl mx-auto">
        <div class="flex items-center gap-4 mb-12" data-reveal>
          <span class="text-[10px] font-semibold text-[var(--accent)] tracking-[0.3em] uppercase">Projects</span>
          <span class="h-px flex-1 bg-gradient-to-r from-[rgba(162,201,255,0.45)] to-transparent section-line"></span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {projects.map((project, index) => (
              <div
                  class={`card-glow surface-panel group relative rounded-[14px] p-6 ${
                      index < 2
                          ? 'card-featured border-t-2 border-t-[var(--accent)]'
                          : 'border-t border-t-[rgba(255,255,255,0.12)]'
                  }`}
                  data-reveal data-delay={index * 60}
              >
                <!-- Top glow for featured cards -->
                {index < 2 && (
                    <div class="pointer-events-none absolute inset-x-0 top-0 h-24 rounded-t-[14px] bg-gradient-to-b from-[rgba(162,201,255,0.08)] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                )}

                <div class="flex justify-between items-start mb-4">
                  <h4 class="text-[var(--text)] font-[600] text-[15px] group-hover:text-white transition-colors duration-200">
                    {project.title}
                  </h4>
                  {(project.githubUrl || project.demoUrl) && (
                      <ExternalLink size={14} class="text-[var(--muted-2)] group-hover:text-[var(--accent)] transition-colors duration-200 shrink-0 mt-0.5" />
                  )}
                </div>

                <p class="text-[13px] text-[var(--text-body)] leading-[1.65] mb-6">{project.description}</p>

                <div class="flex flex-wrap gap-2 mt-auto">
                  {project.techStack.map(tech => (
                      <span class="tech-tag font-mono text-[10px] bg-[rgba(255,255,255,0.03)] border border-[var(--border)] text-[var(--muted)] rounded px-2 py-0.5 cursor-default">
                    {tech}
                  </span>
                  ))}
                </div>
              </div>
          ))}
        </div>
      </section>

      <hr class="section-divider" />

      <!-- ─── Section: Skills ──────────────────────────── -->
      <section id="skills" data-section="skills" class="content-section py-12 px-6 md:px-14 max-w-5xl mx-auto">
        <div class="flex items-center gap-4 mb-12" data-reveal>
          <span class="text-[10px] font-semibold text-[var(--accent)] tracking-[0.3em] uppercase">Skills</span>
          <span class="h-px flex-1 bg-gradient-to-r from-[rgba(162,201,255,0.45)] to-transparent section-line"></span>
        </div>

        <div class="space-y-8">
          {skillCategories.map((category, index) => (
              <div class="grid md:grid-cols-[180px_1fr] gap-4 items-start" data-reveal data-delay={index * 50}>
                <div class="text-[10px] uppercase tracking-widest text-[var(--muted-2)] font-semibold mt-1.5">
                  {category.category}
                </div>

                <div class="flex flex-wrap gap-2">
                  {category.skills.map(skill => (
                      <span class="tech-tag border border-[var(--border)] bg-[rgba(255,255,255,0.03)] rounded px-2.5 py-1 text-[12px] text-[var(--muted)] cursor-default">
                    {skill}
                  </span>
                  ))}
                </div>
              </div>
          ))}
        </div>
      </section>

      <hr class="section-divider" />

      <!-- ─── Section: Education ───────────────────────── -->
      <section id="education" data-section="education" class="content-section py-12 px-6 md:px-14 max-w-5xl mx-auto">
        <div class="flex items-center gap-4 mb-12" data-reveal>
          <span class="text-[10px] font-semibold text-[var(--accent)] tracking-[0.3em] uppercase">Education</span>
          <span class="h-px flex-1 bg-gradient-to-r from-[rgba(162,201,255,0.45)] to-transparent section-line"></span>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <!-- University card -->
          <div
              class="card-glow card-featured surface-panel border-t-2 border-t-[var(--accent)] rounded-[14px] p-6"
              data-reveal
          >
            <div class="text-[11px] text-[var(--muted-2)] font-mono mb-2 tracking-wider">Sep 2021 — Jun 2025</div>
            <h4 class="text-white font-[600] text-[15px] mb-1">VNU-HCM University of Information Technology</h4>
            <div class="text-[13px] text-[var(--accent)] opacity-90 mb-4">Bachelor of Information Technology</div>

            <div class="inline-flex items-center gap-2 bg-[rgba(162,201,255,0.1)] border border-[rgba(162,201,255,0.26)] rounded px-3 py-1 mb-4">
              <span class="text-[12px] text-[var(--text-body)]">GPA <span>8.38</span> / 10.0</span>
            </div>

            <div>
              <div class="text-[10px] uppercase tracking-widest text-[var(--muted-2)] font-semibold mb-3">Coursework</div>
              <div class="flex flex-wrap gap-2">
                {['Operating Systems', 'Computer Networks', 'Data Structures & Algorithms', 'OOP', 'Web Development', 'Computer Systems'].map(course => (
                    <span class="font-mono text-[10px] bg-[rgba(255,255,255,0.03)] border border-[var(--border)] text-[var(--muted)] rounded px-2 py-0.5">{course}</span>
                ))}
              </div>
            </div>
          </div>

          <!-- TOEIC card -->
          <div
              class="card-glow surface-panel border-t border-t-[rgba(255,255,255,0.12)] rounded-[14px] p-6"
              data-reveal data-delay="60"
          >
            <div class="text-[11px] text-[var(--muted-2)] font-mono mb-2">English Proficiency</div>
            <h4 class="text-white font-[600] text-[15px] mb-1">TOEIC Certificate</h4>

            <div class="space-y-2 mt-4 text-[13px] text-[var(--text-body)]">
              <div class="flex justify-between border-b border-[var(--border)] pb-2">
                <span>Listening &amp; Reading</span>
                <span class="text-white font-semibold">770</span>
              </div>
              <div class="flex justify-between pt-1">
                <span>Speaking &amp; Writing</span>
                <span class="text-white font-semibold">250</span>
              </div>
            </div>
          </div>
        </div>
      </section>

    </main>
  </div>
</BaseLayout>

