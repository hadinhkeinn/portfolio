---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import { experiences } from '../data/experience';
import { skillCategories } from '../data/skills';
import { projects } from '../data/projects';
import { ArrowRight, ExternalLink, Mail } from 'lucide-astro';

const siteUrl = 'https://portfolio.dinhkien.id.vn';
const pageTitle = 'Ha Dinh Kien | Full-Stack Software Engineer';
const pageDescription = 'Full-stack software engineer in Ho Chi Minh City building scalable SaaS products, real-time systems, and AI-enabled web platforms.';
const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Ha Dinh Kien',
  jobTitle: 'Full-Stack Software Engineer',
  url: siteUrl,
  image: `${siteUrl}/avt.png`,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Ho Chi Minh City',
    addressCountry: 'VN'
  },
  sameAs: [
    'https://github.com/hadinhkeinn',
    'https://linkedin.com/in/hadinhkienn'
  ]
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/"
  jsonLd={personJsonLd}
>
  <div class="min-h-screen">
    <Sidebar />
    <main class="site-main min-h-screen md:pl-70 pb-16">

      <!-- ─── Section: About ───────────────────────────── -->
      <section id="about" data-section="about" class="content-section hero-section">
        <div class="hero-shell">
          <h1 class="hero-title" data-reveal data-delay="30">
            Building fast, reliable digital products.
          </h1>

          <p class="hero-copy" data-reveal data-delay="70">
            I'm Kien, a full-stack software engineer based in Ho Chi Minh City. I build scalable SaaS products, real-time systems, and AI-enabled platforms with a focus on reliability, maintainability, and product impact.
            At CT UAV, I work on distributed drone monitoring and swarm-control systems powered by real-time communication architecture.
            Previously at CHEK JSC, I helped build a multi-tenant business platform across backend services, frontend applications, and cloud deployment workflows.
            <br /><br />
            I enjoy turning complex engineering problems into clean systems that are practical to operate and easy to evolve.
          </p>

          <div class="hero-actions" data-reveal data-delay="110">
            <a href="#projects" class="hero-button hero-button-primary">
              View projects
              <ArrowRight size={16} />
            </a>
            <a href="mailto:hadinhkienn@gmail.com" class="hero-button hero-button-secondary">
              <Mail size={16} />
              Contact
            </a>
          </div>
        </div>
      </section>

      <hr class="section-divider" />

      <!-- ─── Section: Experience ──────────────────────── -->
      <section id="experience" data-section="experience" class="content-section section-block">
        <div class="section-heading" data-reveal>
          <h2 class="section-eyebrow">Experience</h2>
          <span class="section-line"></span>
        </div>

        <div class="timeline-list">
          {experiences.map((exp, index) => (
              <div class="timeline-item" data-reveal data-delay={index * 60}>
                <!-- Timeline dot -->
                <div class={`timeline-dot ${
                    exp.isCurrent
                        ? 'timeline-dot-current dot-accent-pulse'
                        : 'timeline-dot-muted'
                }`}></div>

                <div class="timeline-date">
                  {exp.startDate} — {exp.endDate}
                </div>

                <h3 class="timeline-title">
                  {exp.role}
                  {exp.isCurrent && (
                      <span class="current-badge">
                    <span class="badge-dot dot-pulse" aria-hidden="true"></span>
                    Now
                  </span>
                  )}
                </h3>

                <div class="timeline-company">{exp.company}</div>

                <p class="timeline-description">{exp.description}</p>

                <ul class="timeline-highlights">
                  {exp.highlights.map(hl => (
                      <li class="exp-item">{hl}</li>
                  ))}
                </ul>

                <div class="tag-list">
                  {exp.techStack.map(tech => (
                      <span class="tech-tag tech-tag-accent">
                    {tech}
                  </span>
                  ))}
                </div>
              </div>
          ))}
        </div>
      </section>

      <hr class="section-divider" />

      <!-- ─── Section: Projects ────────────────────────── -->
      <section id="projects" data-section="projects" class="content-section section-block">
        <div class="section-heading" data-reveal>
          <h2 class="section-eyebrow">Projects</h2>
          <span class="section-line"></span>
        </div>

        <div class="project-grid">
          {projects.map((project, index) => (
              <div
                  class={`portfolio-card project-card group ${
                      index < 2
                          ? 'card-featured'
                          : ''
                  }`}
                  data-reveal data-delay={index * 60}
              >
                <!-- Top glow for featured cards -->
                {index < 2 && (
                    <div class="card-top-glow" aria-hidden="true"></div>
                )}

                <div class="card-title-row">
                  <h3 class="card-title">
                    {project.title}
                  </h3>
                  {(project.githubUrl || project.demoUrl) && (
                      <ExternalLink size={14} class="card-link-icon" />
                  )}
                </div>

                <p class="card-description">{project.description}</p>

                <div class="tag-list mt-auto">
                  {project.techStack.map(tech => (
                      <span class="tech-tag">
                    {tech}
                  </span>
                  ))}
                </div>
              </div>
          ))}
        </div>
      </section>

      <hr class="section-divider" />

      <!-- ─── Section: Skills ──────────────────────────── -->
      <section id="skills" data-section="skills" class="content-section section-block">
        <div class="section-heading" data-reveal>
          <h2 class="section-eyebrow">Skills</h2>
          <span class="section-line"></span>
        </div>

        <div class="skills-list">
          {skillCategories.map((category, index) => (
              <div class="skill-row" data-reveal data-delay={index * 50}>
                <div class="skill-category">
                  {category.category}
                </div>

                <div class="tag-list">
                  {category.skills.map(skill => (
                      <span class="tech-tag skill-tag">
                    {skill}
                  </span>
                  ))}
                </div>
              </div>
          ))}
        </div>
      </section>

      <hr class="section-divider" />

      <!-- ─── Section: Education ───────────────────────── -->
      <section id="education" data-section="education" class="content-section section-block">
        <div class="section-heading" data-reveal>
          <h2 class="section-eyebrow">Education</h2>
          <span class="section-line"></span>
        </div>

        <div class="education-grid">
          <!-- University card -->
          <div
              class="portfolio-card card-featured"
              data-reveal
          >
            <div class="card-meta">Sep 2021 — Jun 2025</div>
            <h3 class="card-title">VNU-HCM University of Information Technology</h3>
            <div class="card-subtitle">Bachelor of Information Technology</div>

            <div class="metric-pill">
              <span>GPA <span class="metric-value">8.38</span> / 10.0</span>
            </div>

            <div>
              <div class="mini-label">Coursework</div>
              <div class="tag-list">
                {['Operating Systems', 'Computer Networks', 'Data Structures & Algorithms', 'OOP', 'Web Development', 'Computer Systems'].map(course => (
                    <span class="tech-tag">{course}</span>
                ))}
              </div>
            </div>
          </div>

          <!-- TOEIC card -->
          <div
              class="portfolio-card"
              data-reveal data-delay="60"
          >
            <div class="card-meta">English Proficiency</div>
            <h3 class="card-title">TOEIC Certificate</h3>

            <div class="score-list">
              <div class="score-row">
                <span>Listening &amp; Reading</span>
                <span>770</span>
              </div>
              <div class="score-row">
                <span>Speaking &amp; Writing</span>
                <span>250</span>
              </div>
            </div>
          </div>
        </div>
      </section>

    </main>
  </div>
</BaseLayout>
